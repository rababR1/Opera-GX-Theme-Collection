{
  "name": "Rosé Pine",
  "description": "Ports the popular VS Code and Nvim theme, Rosé Pine, to Opera GX. Includes both the original theme and the Moon flavour(s)",
  "developer": {
    "name": "TG101"
  },
  "icons": {
    "512": "icon_512.png"
  },
  "manifest_version": 3,
  "mod": {
    "license": "license.txt",
    "payload": {
      "background_music": [
        "music/track_1.mp3",
        "music/track_2.mp3",
        "music/track_3.mp3",
        "music/track_4.mp3"
      ],
      "browser_sounds": {
        "CLICK": ["sound/click.mp3"],
        "FEATURE_SWITCH_OFF": ["sound/feature_switch_off.mp3"],
        "FEATURE_SWITCH_ON": ["sound/feature_switch_on.mp3"],
        "HOVER": ["sound/hover.mp3"],
        "HOVER_UP": ["sound/hover.mp3"],
        "IMPORTANT_CLICK": ["sound/important_click.mp3"],
        "LEVEL_UPGRADE": ["sound/level_upgrade.mp3"],
        "LIMITER_OFF": ["sound/limiter_off.mp3"],
        "LIMITER_ON": ["sound/limiter_on.mp3"],
        "SWITCH_TOGGLE": ["sound/switch.mp3"],
        "TAB_CLOSE": ["sound/close_tab.mp3"],
        "TAB_INSERT": ["sound/new_tab.mp3"],
        "TAB_SLASH": ["sound/tab_slash.mp3"]
      },
      "keyboard_sounds": {
        "TYPING_BACKSPACE": ["keyboard/backspace.wav"],
        "TYPING_ENTER": ["keyboard/enter.wav"],
        "TYPING_LETTER": [
          "keyboard/letter_1.wav",
          "keyboard/letter_2.wav",
          "keyboard/letter_3.wav"
        ],
        "TYPING_SPACE": ["keyboard/space.wav"]
      },
      "cursors": [
        {
          "id": "cursors_dark",
          "name": "Rosé Pine Dark",
          "preview": "icon_512.png",
          "items": [
            {
              "type": "POINTER",
              "path": "cursors/dark/Default.cur"
            },
            {
              "type": "HELP",
              "path": "cursors/dark/Help.cur"
            },
            {
              "type": "PROGRESS",
              "path": "cursors/dark/Busy.ani"
            },
            {
              "type": "WAIT",
              "path": "cursors/dark/Work.ani"
            },
            {
              "type": "CROSS",
              "path": "cursors/dark/Cross.cur"
            },
            {
              "type": "I_BEAM",
              "path": "cursors/dark/IBeam.cur"
            },
            {
              "type": "HAND",
              "path": "cursors/dark/Link.cur"
            },
            {
              "type": "MOVE",
              "path": "cursors/dark/Move.cur"
            },
            {
              "type": "NOT_ALLOWED",
              "path": "cursors/dark/Unavailiable.cur"
            },
            {
              "type": "EAST_WEST_RESIZE",
              "path": "cursors/dark/Horizontal.cur"
            },
            {
              "type": "NORTH_SOUTH_RESIZE",
              "path": "cursors/dark/Vertical.cur"
            },
            {
              "type": "NORTH_WEST_SOUTH_EAST_RESIZE",
              "path": "cursors/dark/Diagonal_1.cur"
            },
            {
              "type": "NORTH_EAST_SOUTH_WEST_RESIZE",
              "path": "cursors/dark/Diagonal_2.cur"
            }
          ]
        },
        {
          "id": "cursors_light",
          "name": "Rosé Pine Light",
          "preview": "icon_512.png",
          "items": [
            {
              "type": "POINTER",
              "path": "cursors/light/Default.cur"
            },
            {
              "type": "HELP",
              "path": "cursors/light/Help.cur"
            },
            {
              "type": "PROGRESS",
              "path": "cursors/light/Busy.ani"
            },
            {
              "type": "WAIT",
              "path": "cursors/light/Work.ani"
            },
            {
              "type": "CROSS",
              "path": "cursors/light/Cross.cur"
            },
            {
              "type": "I_BEAM",
              "path": "cursors/light/IBeam.cur"
            },
            {
              "type": "HAND",
              "path": "cursors/light/Link.cur"
            },
            {
              "type": "MOVE",
              "path": "cursors/light/Move.cur"
            },
            {
              "type": "NOT_ALLOWED",
              "path": "cursors/light/Unavailiable.cur"
            },
            {
              "type": "EAST_WEST_RESIZE",
              "path": "cursors/light/Horizontal.cur"
            },
            {
              "type": "NORTH_SOUTH_RESIZE",
              "path": "cursors/light/Vertical.cur"
            },
            {
              "type": "NORTH_WEST_SOUTH_EAST_RESIZE",
              "path": "cursors/light/Diagonal_1.cur"
            },
            {
              "type": "NORTH_EAST_SOUTH_WEST_RESIZE",
              "path": "cursors/light/Diagonal_2.cur"
            }
          ]
        }
      ],
      "page_styles": [
        {
          "css": ["webmodding/opera.css"],
          "matches": ["https://*.opera.com/*"]
        }
      ],
      "shaders": {
        "Matrix green": {
          "path": "shader/matrix.txt"
        },
        "Wave": {
          "animation": {
            "duration": 60,
            "steps": 3600
          },
          "path": "shader/wave.txt"
        }
      },
      "theme": [
        {
          "id": "rose_pine",
          "name": "Rosé Pine",
          "dark": {
            "gx_accent": {
              "h": 2,
              "s": 55,
              "l": 83
            },
            "gx_secondary_base": {
              "h": 249,
              "s": 22,
              "l": 12
            }
          },
          "light": {
            "gx_accent": {
              "h": 3,
              "s": 53,
              "l": 67
            },
            "gx_secondary_base": {
              "h": 32,
              "s": 57,
              "l": 95
            }
          }
        },
        {
          "id": "rose_pine_moon",
          "name": "Rosé Pine Moon",
          "dark": {
            "gx_accent": {
              "h": 2,
              "s": 66,
              "l": 75
            },
            "gx_secondary_base": {
              "h": 246,
              "s": 23,
              "l": 17
            }
          },
          "light": {
            "gx_accent": {
              "h": 3,
              "s": 53,
              "l": 67
            },
            "gx_secondary_base": {
              "h": 32,
              "s": 57,
              "l": 95
            }
          }
        }
      ],
      "wallpaper": [
