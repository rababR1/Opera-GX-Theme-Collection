            "text_color": "#e0def4",
            "text_shadow": "#908caa"
          },
          "light": {
            "image": "wallpaper/light1.png",
            "text_color": "#575279",
            "text_shadow": "#797593"
          }
        },
        {
          "id": "wallpaper_2",
